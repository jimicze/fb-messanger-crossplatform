<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.lasakondrej.MessengerX</id>

  <name>Messenger X</name>
  <summary>Cross-platform desktop client for Facebook Messenger</summary>

  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      Messenger X is a lightweight, cross-platform desktop client for Facebook Messenger
      built with Tauri. It wraps messenger.com in a native window with full desktop
      integration: system tray, native notifications, zoom controls, offline detection
      with cached snapshot fallback, and automatic updates.
    </p>
    <p>Features:</p>
    <ul>
      <li>Native desktop notifications with sound</li>
      <li>System tray integration with quick settings</li>
      <li>Persistent login across restarts</li>
      <li>Offline mode with cached snapshot fallback</li>
      <li>Zoom controls (60 %–120 %)</li>
      <li>Start at login and minimize to tray on startup</li>
      <li>Automatic background updates</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.lasakondrej.MessengerX.desktop</launchable>

  <url type="homepage">https://github.com/jimicze/fb-messanger-crossplatform</url>
  <url type="bugtracker">https://github.com/jimicze/fb-messanger-crossplatform/issues</url>
  <url type="vcs-browser">https://github.com/jimicze/fb-messanger-crossplatform</url>

